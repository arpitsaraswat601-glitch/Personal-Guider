{
  "expo": {
    "name": "Personal Guider",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.jpg",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.personalguider.app"
    },
    "android": {
      "backgroundColor": "#0A0A0A",
      "package": "com.personalguider.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.jpg",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "favicon": "./assets/images/logo.jpg",
      "bundler": "metro",
      "output": "static",
      "name": "Personal Guider",
      "shortName": "Guider",
      "description": "Your silent self-discipline and recovery companion.",
      "themeColor": "#FF6B35",
      "backgroundColor": "#0A0A0A",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
